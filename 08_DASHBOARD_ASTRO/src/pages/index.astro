---
import Layout from "../components/Layout.astro";

const milestones = [
  ["Paper base", "Siddiqui & Afzal (2022)"],
  ["HHI UAE", "Replica activa"],
  ["DEA UAE", "Auditoria activa"],
  ["Extension Ecuador", "Activa"],
  ["Revista objetivo", "MLAJ"],
  ["Latindex", "PENDIENTE_VERIFICAR"]
];

const sections = [
  ["Literatura", "PDF base y literatura complementaria sobre diversificacion, recursos y conocimiento."],
  ["HHI", "Replica de la Tabla 3 del UAE con GFCF por 18 sectores."],
  ["DEA", "Auditoria CCR del paper original y prueba de adecuacion de DMUs."],
  ["Ecuador", "HHI por ramas ISIC y ejercicios DEA exploratorios y sectoriales."],
  ["Submission", "MLAJ como revista objetivo; indexacion Latindex pendiente de verificacion."]
];
---
<Layout title="Dashboard de replica Afzal UAE">
  <section class="hero">
    <div class="status">Replica del paper base</div>
    <h1>Diversificacion sectorial del UAE</h1>
    <p>
      Monitoreo de la replica del paper de Siddiqui y Afzal, la auditoria metodologica
      del DEA CCR y la extension a Ecuador. El proyecto mantiene el tema original del
      repositorio y evita mezclarlo con lineas ajenas.
    </p>
  </section>

  <section class="band">
    <h2>Avance</h2>
    <div class="grid">
      {milestones.map(([label, value]) => (
        <article class="panel">
          <h3>{label}</h3>
          <p>{value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="band">
    <h2>Modulos</h2>
    <div class="grid">
      {sections.map(([label, text]) => (
        <article class="panel">
          <h3>{label}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="band">
    <h2>Rutas clave</h2>
    <table class="panel">
      <thead>
        <tr>
          <th>Componente</th>
          <th>Ruta</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Codigo principal</td><td><span class="mono">src/</span></td></tr>
        <tr><td>Reporte original</td><td><span class="mono">paper/replication_report.qmd</span></td></tr>
        <tr><td>Literatura</td><td><span class="mono">01_LITERATURA/PAPERS/</span></td></tr>
        <tr><td>Resultados</td><td><span class="mono">outputs/tables/ y outputs/figures/</span></td></tr>
        <tr><td>Submission</td><td><span class="mono">07_SUBMISSION/</span></td></tr>
      </tbody>
    </table>
  </section>
</Layout>
