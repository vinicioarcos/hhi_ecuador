---
const { title = "Dashboard de Replica HHI/DEA" } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f4efe6;
        --ink: #1f2933;
        --accent: #c84c09;
        --accent-soft: #f1c8a6;
        --panel: rgba(255, 252, 247, 0.9);
        --line: #d6c5b2;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, #fff7e9 0, transparent 30%),
          linear-gradient(180deg, #efe4d2 0%, var(--bg) 100%);
      }
      main {
        max-width: 1180px;
        margin: 0 auto;
        padding: 24px;
      }
      h1, h2, h3 { letter-spacing: 0; }
      .hero {
        min-height: 42vh;
        display: grid;
        align-content: end;
        padding: 48px 0 24px;
      }
      .hero h1 {
        font-size: clamp(2.4rem, 6vw, 4.8rem);
        margin: 0 0 12px;
      }
      .hero p {
        max-width: 760px;
        font-size: 1.05rem;
        line-height: 1.5;
        margin: 0;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }
      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 18px;
        backdrop-filter: blur(6px);
      }
      .band {
        padding: 18px 0 10px;
      }
      .status {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: #6f2d06;
        font-size: 0.88rem;
      }
      .mono {
        font-family: "Courier New", monospace;
        font-size: 0.92rem;
      }
      a { color: #7a2f05; }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th, td {
        padding: 10px 8px;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
